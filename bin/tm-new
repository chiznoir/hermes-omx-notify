#!/usr/bin/env bash
set -euo pipefail

canonical_name="tm-new"
project_dir="$PWD"
session_name=""
attach=0
direct_mode=0
print_json=0
bridge_check=1
backend="omx"
omx_runs_dir="${OMX_RUNS_DIR:-}"
runs_dir_option=0
worktree_path=""
gjc_run_dir=""
gjc_project=""
gjc_verify_error=""
extra_args=()

usage() {
  cat <<'USAGE'
Usage:
  tm-new [a] [PROJECT_DIR] [--name SESSION] [--attach] [--direct] [--json] [--runs PATH] [--no-check] [-- OMX_ARGS...]
  tm-new [a] --gjc [PROJECT_DIR] [--name SESSION] [--worktree PATH] [--json] [--no-check] [-- GJC_ARGS...]

Description:
  Canonical helper on hermes-tmux-bridge is tm-new.
  By default it starts a visible OMX/Codex tmux session and runs `omx --madmax --high`.
  Use `a`, `-a`, or `--attach` to attach after creating the tmux session.
  Use `--gjc` only when you explicitly want a GJC external-runner session:
    tm-new --gjc              -> gjc --tmux
    tm-new --gjc --worktree P -> gjc --tmux --worktree P
  `a` is a reserved attach token before `--`; use `./a` for a directory named a.
  `--direct` is OMX-only and runs OMX in the current terminal instead of creating a tmux session.
  `--runs/--runs-dir` is OMX-only and is not supported with --gjc.

Examples:
  tm-new ~/work/hermes-tmux-bridge
  tm-new a .
  tm-new . a --name hermes-main
  tm-new ~/work/app -- --model gpt-5.5
  tm-new --gjc .
  tm-new --gjc . a
  tm-new --gjc . --worktree ../task-worktree -- --model opus
USAGE
}

log() { printf '%s\n' "$*" >&2; }
die() { printf 'error: %s\n' "$*" >&2; exit 1; }
require_cmd() { command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"; }

cleanup_gjc_session() {
  [[ "$backend" == "gjc" && -n "${session_name:-}" ]] || return 0
  if tmux has-session -t "$session_name" 2>/dev/null; then
    tmux kill-session -t "$session_name" >/dev/null 2>&1 || log "warning: failed to clean up GJC tmux session after failed launch: $session_name"
  fi
}

die_gjc_launch() {
  local message="$1"
  cleanup_gjc_session
  die "$message"
}

slugify() {
  local raw="$1" slug
  slug="$(printf '%s' "$raw" | tr -cs '[:alnum:]_.-' '-' | sed 's/^-*//; s/-*$//')"
  printf '%s' "${slug:-project}"
}

auto_name() {
  printf '%s-%s-%s' "$backend" "$(slugify "$(basename "$project_dir")")" "$(date +%H%M%S)"
}

quote_cmd() {
  local out=() arg
  for arg in "$@"; do
    out+=("$(printf '%q' "$arg")")
  done
  printf '%s ' "${out[@]}"
}

session_option_value() {
  tmux show-options -t "$1" -vq "$2" 2>/dev/null || true
}

gjc_session_roots() {
  if [[ -n "${GJC_SESSIONS_ROOT:-}" ]]; then
    printf '%s' "$GJC_SESSIONS_ROOT"
    return
  fi
  local xdg_root="${XDG_DATA_HOME:-$HOME/.local/share}"
  printf '%s:%s' "$HOME/.gjc/agent/sessions" "$xdg_root/gjc/sessions"
}

list_existing_gjc_session_ids() {
  local roots="$1"
  GJC_SESSION_ROOTS="$roots" GJC_EXPECTED_CWD="$gjc_run_dir" node - <<'NODE'
const fs = require('node:fs');
const path = require('node:path');
const roots = String(process.env.GJC_SESSION_ROOTS || '').split(path.delimiter).filter(Boolean);
const expectedCwd = process.env.GJC_EXPECTED_CWD || '';
const ids = new Set();
function consider(file) {
  let firstLine = '';
  try { firstLine = fs.readFileSync(file, 'utf8').split('\n', 1)[0]; }
  catch { return; }
  if (!firstLine.trim()) return;
  let record;
  try { record = JSON.parse(firstLine); }
  catch { return; }
  if (record?.type === 'session' && record?.cwd === expectedCwd && record?.id) ids.add(String(record.id));
}
function walk(dir) {
  let entries;
  try { entries = fs.readdirSync(dir, { withFileTypes: true }); }
  catch { return; }
  for (const entry of entries) {
    const full = path.join(dir, entry.name);
    if (entry.isDirectory()) walk(full);
    else if (entry.isFile() && entry.name.endsWith('.jsonl')) consider(full);
  }
}
for (const root of roots) walk(root);
process.stdout.write([...ids].sort().join('\n'));
NODE
}

discover_gjc_session_id() {
  local roots="$1" existing_ids="$2"
  GJC_SESSION_ROOTS="$roots" GJC_EXPECTED_CWD="$gjc_run_dir" GJC_STARTED_AT="$gjc_started_at" GJC_EXISTING_SESSION_IDS="$existing_ids" node - <<'NODE'
const fs = require('node:fs');
const path = require('node:path');
const roots = String(process.env.GJC_SESSION_ROOTS || '').split(path.delimiter).filter(Boolean);
const expectedCwd = process.env.GJC_EXPECTED_CWD || '';
const startedAtMs = Date.parse(process.env.GJC_STARTED_AT || '');
const existing = new Set(String(process.env.GJC_EXISTING_SESSION_IDS || '').split(/\r?\n/).filter(Boolean));
const candidates = [];
function consider(file) {
  let firstLine = '';
  try { firstLine = fs.readFileSync(file, 'utf8').split('\n', 1)[0]; }
  catch { return; }
  if (!firstLine.trim()) return;
  let record;
  try { record = JSON.parse(firstLine); }
  catch { return; }
  if (record?.type !== 'session' || record?.cwd !== expectedCwd || !record?.id) return;
  const id = String(record.id);
  if (existing.has(id)) return;
  const recordMs = Date.parse(record.timestamp || '');
  if (Number.isFinite(startedAtMs) && Number.isFinite(recordMs) && recordMs + 30000 < startedAtMs) return;
  let score = Number.isFinite(recordMs) ? recordMs : 0;
  try {
    const stat = fs.statSync(file);
    score = Math.max(score, stat.mtimeMs || 0);
  } catch {}
  candidates.push({ id, score, file });
}
function walk(dir) {
  let entries;
  try { entries = fs.readdirSync(dir, { withFileTypes: true }); }
  catch { return; }
  for (const entry of entries) {
    const full = path.join(dir, entry.name);
    if (entry.isDirectory()) walk(full);
    else if (entry.isFile() && entry.name.endsWith('.jsonl')) consider(full);
  }
}
for (const root of roots) walk(root);
candidates.sort((a, b) => b.score - a.score);
if (candidates.length === 1) process.stdout.write(candidates[0].id);
else if (candidates.length > 1) {
  process.stdout.write(`AMBIGUOUS:${candidates.map(item => `${item.id}@${item.file}`).join(',')}`);
  process.exit(2);
}
NODE
}

wait_for_gjc_session_id() {
  local roots="$1" existing_ids="$2" discovered_session_id=''
  for _ in $(seq 1 40); do
    discovered_session_id="$(discover_gjc_session_id "$roots" "$existing_ids")" || {
      if [[ "$discovered_session_id" == AMBIGUOUS:* ]]; then
        printf '%s' "$discovered_session_id"
        return 2
      fi
      return 1
    }
    if [[ -n "$discovered_session_id" ]]; then
      printf '%s' "$discovered_session_id"
      return 0
    fi
    sleep 0.25
  done
  return 1
}

verify_gjc_managed_profile() {
  local target="$1"
  local gjc_profile gjc_branch gjc_branch_slug managed_gjc_project gjc_owner_key_value gjc_started_at_value gjc_session_tag expected_branch_slug
  gjc_verify_error=""
  gjc_profile="$(session_option_value "$target" '@gjc-profile')"
  gjc_branch="$(session_option_value "$target" '@gjc-branch')"
  gjc_branch_slug="$(session_option_value "$target" '@gjc-branch-slug')"
  managed_gjc_project="$(session_option_value "$target" '@gjc-project')"
  gjc_owner_key_value="$(session_option_value "$target" '@gjc-owner-key')"
  gjc_started_at_value="$(session_option_value "$target" '@gjc-started-at')"
  gjc_session_tag="$(session_option_value "$target" '@gjc-session-id')"
  if [[ "$gjc_profile" != '1' ]]; then
    gjc_verify_error="GJC tmux session missing @gjc-profile=1: $target"
    return 1
  fi
  if [[ "$gjc_branch" != 'gjc' ]]; then
    gjc_verify_error="GJC tmux session has inconsistent @gjc-branch: expected gjc, got ${gjc_branch:-<empty>}"
    return 1
  fi
  expected_branch_slug="$(slugify "$gjc_branch")"
  if [[ "$gjc_branch_slug" != "$expected_branch_slug" ]]; then
    gjc_verify_error="GJC tmux session has inconsistent @gjc-branch-slug: expected $expected_branch_slug, got ${gjc_branch_slug:-<empty>}"
    return 1
  fi
  if [[ "$managed_gjc_project" != "$gjc_project" ]]; then
    gjc_verify_error="GJC tmux session project mismatch: expected $gjc_project, got ${managed_gjc_project:-<empty>}"
    return 1
  fi
  if [[ "$gjc_owner_key_value" != "$gjc_owner_key" ]]; then
    gjc_verify_error="GJC tmux session owner key mismatch: $target"
    return 1
  fi
  if [[ "$gjc_started_at_value" != "$gjc_started_at" ]]; then
    gjc_verify_error="GJC tmux session started-at mismatch: $target"
    return 1
  fi
  if [[ "$gjc_session_tag" != "$gjc_session_id" ]]; then
    gjc_verify_error="GJC tmux session id tag mismatch: $target"
    return 1
  fi
}

json_escape() {
  local value="${1:-}"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

emit_result_json() {
  local command_text="$1" message="$2"
  printf '{"ok":true,"backend":"%s"' "$(json_escape "$backend")"
  if [[ -n "$session_name" ]]; then
    printf ',"tmuxId":"%s"' "$(json_escape "$session_name")"
  fi
  if [[ -n "${pane_id:-}" ]]; then
    printf ',"tmuxPaneId":"%s"' "$(json_escape "$pane_id")"
  fi
  printf ',"projectDir":"%s"' "$(json_escape "$project_dir")"
  printf ',"managed":%s' "$([[ "$backend" == "gjc" ]] && printf true || printf false)"
  printf ',"attach":%s' "$([[ "$attach" -eq 1 ]] && printf true || printf false)"
  if [[ -n "$omx_runs_dir" && "$backend" == "omx" ]]; then
    printf ',"omxRunsDir":"%s"' "$(json_escape "$omx_runs_dir")"
  fi
  if [[ -n "$worktree_path" && "$backend" == "gjc" ]]; then
    printf ',"worktree":"%s"' "$(json_escape "$worktree_path")"
  fi
  if [[ -n "$command_text" ]]; then
    printf ',"command":"%s"' "$(json_escape "$command_text")"
  fi
  if [[ -n "$message" ]]; then
    printf ',"message":"%s"' "$(json_escape "$message")"
  fi
  printf '}\n'
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    a) attach=1; shift ;;
    --gjc) backend="gjc"; shift ;;
    --name|-n) [[ $# -ge 2 ]] || die "missing session name after --name"; session_name="$2"; shift 2 ;;
    --attach|-a) attach=1; shift ;;
    --direct|-d) direct_mode=1; shift ;;
    --json) print_json=1; shift ;;
    --runs|--runs-dir) [[ $# -ge 2 ]] || die "missing path after $1"; omx_runs_dir="$2"; runs_dir_option=1; shift 2 ;;
    --worktree) [[ $# -ge 2 ]] || die "missing path after --worktree"; worktree_path="$2"; shift 2 ;;
    --no-check|--no-bridge-check) bridge_check=0; shift ;;
    --) shift; extra_args=("$@"); break ;;
    -*) die "unknown option: $1" ;;
    *) project_dir="$1"; shift ;;
  esac
done

project_dir="$(cd "$project_dir" && pwd)"
if [[ -n "$worktree_path" ]]; then
  [[ "$backend" == "gjc" ]] || die "--worktree is only supported with --gjc"
  worktree_path="$(cd "$project_dir" && node -e 'process.stdout.write(require("node:path").resolve(process.argv[1]))' "$worktree_path")"
fi
if [[ "$backend" == "gjc" && "$runs_dir_option" -eq 1 ]]; then
  die "--runs/--runs-dir is not supported with --gjc"
fi
if [[ "$backend" == "gjc" && "$direct_mode" -eq 1 ]]; then
  die "--direct/-d is not supported with --gjc; use tm-new --gjc so GJC runs through gjc --tmux"
fi
if [[ "$backend" == "omx" && "$runs_dir_option" -eq 1 ]]; then
  mkdir -p "$omx_runs_dir"
  omx_runs_dir="$(cd "$omx_runs_dir" && pwd)"
fi

if [[ "$direct_mode" -eq 1 ]]; then
  [[ "$attach" -eq 0 ]] || die "--direct/-d cannot be combined with attach"
  [[ "$print_json" -eq 0 ]] || die "--direct/-d does not create a tmux session, so --json is not available"
  [[ -z "$session_name" ]] || die "--direct/-d cannot be combined with --name"
  require_cmd omx
  cmd=(omx --direct --yolo)
  if [[ -n "$omx_runs_dir" ]]; then
    cmd=(env "OMX_RUNS_DIR=$omx_runs_dir" "${cmd[@]}")
  fi
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    cmd+=("${extra_args[@]}")
  fi
  cd "$project_dir"
  exec "${cmd[@]}"
fi

require_cmd tmux
session_name="${session_name:-$(auto_name)}"
[[ "$session_name" =~ ^[[:alnum:]_.-]+$ ]] || die "invalid tmux session name: $session_name"

if tmux has-session -t "$session_name" 2>/dev/null; then
  die "tmux session already exists: $session_name"
fi

if [[ "$backend" == "gjc" ]]; then
  require_cmd gjc
  gjc_started_at="$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)"
  gjc_owner_key="${GJC_TMUX_OWNER_KEY:-${session_name}:${gjc_started_at}}"
  gjc_session_roots_value="$(gjc_session_roots)"
  gjc_run_dir="${worktree_path:-$project_dir}"
  gjc_project="$(slugify "$(basename "$gjc_run_dir")")"
  gjc_existing_session_ids="$(list_existing_gjc_session_ids "$gjc_session_roots_value")"
  cmd=(gjc --tmux)
  if [[ -n "$worktree_path" ]]; then
    cmd+=(--worktree "$worktree_path")
  fi
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    cmd+=("${extra_args[@]}")
  fi
  if [[ -n "$session_name" ]]; then
    cmd=(env "GJC_LAUNCH_POLICY=tmux" "GJC_TMUX_SESSION=$session_name" "${cmd[@]}")
  fi
  cmd_text="$(quote_cmd "${cmd[@]}")"
  if ! (cd "$project_dir" && "${cmd[@]}"); then
    die_gjc_launch "GJC native tmux launch failed: $session_name"
  fi
else
  require_cmd omx
  cmd=(omx --madmax --high)
  if [[ -n "$omx_runs_dir" ]]; then
    cmd=(env "OMX_RUNS_DIR=$omx_runs_dir" "${cmd[@]}")
  fi
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    cmd+=("${extra_args[@]}")
  fi
  cmd_text="exec $(quote_cmd "${cmd[@]}")"
  tmux new-session -d -s "$session_name" -c "$project_dir" "$cmd_text"
fi

sleep 1
if ! tmux has-session -t "$session_name" 2>/dev/null; then
  if [[ "$backend" == "gjc" ]]; then
    if [[ "$attach" -eq 1 ]]; then
      if [[ "$print_json" -eq 1 ]]; then
        emit_result_json "$cmd_text" "GJC tmux session ended before post-launch registration"
      else
        log "GJC tmux session ended before post-launch registration: $session_name"
      fi
      exit 0
    fi
    die_gjc_launch "tmux session was not created or is no longer alive: $session_name"
  fi
  die "tmux session was not created or is no longer alive: $session_name"
fi
if [[ "$backend" == "gjc" ]]; then
  if ! {
    tmux set-option -t "$session_name" -q '@gjc-branch' 'gjc' &&
    tmux set-option -t "$session_name" -q '@gjc-branch-slug' 'gjc' &&
    tmux set-option -t "$session_name" -q '@gjc-project' "$gjc_project" &&
    tmux set-option -t "$session_name" -q '@gjc-owner-key' "$gjc_owner_key" &&
    tmux set-option -t "$session_name" -q '@gjc-started-at' "$gjc_started_at"
  }; then
    die_gjc_launch "failed to stamp required GJC tmux session tags: $session_name"
  fi
  if ! gjc_session_id="$(wait_for_gjc_session_id "$gjc_session_roots_value" "$gjc_existing_session_ids")"; then
    if [[ "$gjc_session_id" == AMBIGUOUS:* ]]; then
      die_gjc_launch "ambiguous new GJC session logs for $session_name: ${gjc_session_id#AMBIGUOUS:}"
    fi
    die_gjc_launch "GJC session log was not discovered for managed tmux session: $session_name"
  fi
  if ! tmux set-option -t "$session_name" -q '@gjc-session-id' "$gjc_session_id"; then
    die_gjc_launch "failed to stamp GJC session id for managed tmux session: $session_name"
  fi
  if ! verify_gjc_managed_profile "$session_name"; then
    die_gjc_launch "$gjc_verify_error"
  fi
fi
pane_id="$(tmux list-panes -t "$session_name" -F '#{pane_id}' 2>/dev/null | head -n 1 || true)"

if [[ "$bridge_check" -eq 1 ]]; then
  bridge_url="${OMX_BRIDGE_URL:-http://127.0.0.1:3037}"
  if command -v curl >/dev/null 2>&1; then
    curl -fsS --max-time 2 "$bridge_url/health" >/dev/null 2>&1 || true
  fi
fi

if [[ "$print_json" -eq 1 ]]; then
  emit_result_json "$cmd_text" "$([[ "$backend" == "gjc" ]] && printf 'GJC tmux session created' || printf 'OMX tmux session created')"
else
  log "$([[ "$backend" == "gjc" ]] && printf 'GJC tmux session created' || printf 'OMX tmux session created'): $session_name${pane_id:+ ($pane_id)}"
  log "canonical helper: $canonical_name"
  log "backend: $backend"
  log "project: $project_dir"
  log "command: $cmd_text"
  log "bridge endpoint: ${OMX_BRIDGE_URL:-http://127.0.0.1:3037}/sessions"
fi

if [[ "$attach" -eq 1 ]]; then
  if [[ -n "${TMUX:-}" ]]; then
    exec tmux switch-client -t "$session_name"
  else
    exec tmux attach-session -t "$session_name"
  fi
fi
