#!/usr/bin/env bash
set -euo pipefail

canonical_name="tm-new"
project_dir="$PWD"
session_name=""
attach=0
direct_mode=0
print_json=0
bridge_check=1
legacy_runs_dir="${OMX_RUNS_DIR:-}"
runs_dir_option=0
extra_args=()
created_session=0
cleanup_attempted=0
cleanup_succeeded=0

usage() {
  cat <<'USAGE'
Usage:
  tm-new [PROJECT_DIR] [--name SESSION] [--attach] [--direct] [--json] [--no-check] [-- GJC_ARGS...]

Description:
  Canonical helper on gajae-version is tm-new.
  This script starts a new managed GJC tmux session and verifies GJC ownership tags before success:
    @gjc-profile=1
    @gjc-branch
    @gjc-branch-slug
    @gjc-project
  --direct runs gjc in the current terminal instead of creating a tmux session.
  --runs/--runs-dir is not supported on the branch-fixed gjc backend.

Examples:
  tm-new ~/work/hermes-tmux-bridge
  tm-new . --name hermes-main --attach
  tm-new ~/work/app -- --model sonnet
USAGE
}

log() { printf '%s\n' "$*" >&2; }
die() { printf 'error: %s\n' "$*" >&2; exit 1; }
require_cmd() { command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"; }

slugify() {
  local raw="$1" slug
  slug="$(printf '%s' "$raw" | tr -cs '[:alnum:]_.-' '-' | sed 's/^-*//; s/-*$//')"
  printf '%s' "${slug:-project}"
}

auto_name() {
  printf 'gjc-%s-%s' "$(slugify "$(basename "$project_dir")")" "$(date +%H%M%S)"
}

quote_cmd() {
  local out=() arg
  for arg in "$@"; do
    out+=("$(printf '%q' "$arg")")
  done
  printf '%s ' "${out[@]}"
}

json_escape() {
  local value="${1:-}"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

emit_result_json() {
  local ok="$1"
  local managed="$2"
  local message="$3"
  local command_text="$4"
  local branch="$5"
  local branch_slug="$6"
  local project="$7"
  local runs_note="$8"
  printf '{"ok":%s,"managed":%s' "$ok" "$managed"
  if [[ -n "$session_name" ]]; then
    printf ',"tmuxId":"%s"' "$(json_escape "$session_name")"
  fi
  if [[ -n "${pane_id:-}" ]]; then
    printf ',"tmuxPaneId":"%s"' "$(json_escape "$pane_id")"
  fi
  printf ',"projectDir":"%s"' "$(json_escape "$project_dir")"
  printf ',"ownership":{"gjcProfile":"1","gjcBranch":"%s","gjcBranchSlug":"%s","gjcProject":"%s","gjcOwnerKey":"%s","gjcStartedAt":"%s"}' \
    "$(json_escape "$branch")" "$(json_escape "$branch_slug")" "$(json_escape "$project")" "$(json_escape "$gjc_owner_key")" "$(json_escape "$gjc_started_at")"
  if [[ -n "$command_text" ]]; then
    printf ',"command":"%s"' "$(json_escape "$command_text")"
  fi
  if [[ -n "$message" ]]; then
    if [[ "$ok" == "true" ]]; then
      printf ',"message":"%s"' "$(json_escape "$message")"
    else
      printf ',"error":"%s"' "$(json_escape "$message")"
    fi
  fi
  if [[ -n "$runs_note" ]]; then
    printf ',"runsOption":"%s"' "$(json_escape "$runs_note")"
  fi
  printf ',"cleanupAttempted":%s,"cleanupSucceeded":%s}\n' "$cleanup_attempted" "$cleanup_succeeded"
}

session_option_value() {
  tmux show-options -t "$1" -vq "$2" 2>/dev/null || true
}

gjc_session_roots() {
  if [[ -n "${GJC_SESSIONS_ROOT:-}" ]]; then
    printf '%s' "$GJC_SESSIONS_ROOT"
    return
  fi
  local xdg_root="${XDG_DATA_HOME:-$HOME/.local/share}"
  printf '%s:%s' "$HOME/.gjc/agent/sessions" "$xdg_root/gjc/sessions"
}

discover_gjc_session_id() {
  local roots="$1"
  GJC_SESSION_ROOTS="$roots" PROJECT_DIR="$project_dir" GJC_STARTED_AT="$gjc_started_at" node - <<'NODE'
const fs = require('node:fs');
const path = require('node:path');
const roots = String(process.env.GJC_SESSION_ROOTS || '').split(path.delimiter).filter(Boolean);
const projectDir = process.env.PROJECT_DIR || '';
const startedAtMs = Date.parse(process.env.GJC_STARTED_AT || '');
let best = null;
function consider(file) {
  let firstLine = '';
  try {
    firstLine = fs.readFileSync(file, 'utf8').split('\n', 1)[0];
  } catch {
    return;
  }
  if (!firstLine.trim()) return;
  let record;
  try {
    record = JSON.parse(firstLine);
  } catch {
    return;
  }
  if (record?.type !== 'session' || record?.cwd !== projectDir || !record?.id) return;
  const recordMs = Date.parse(record.timestamp || '');
  if (Number.isFinite(startedAtMs) && Number.isFinite(recordMs) && recordMs + 30000 < startedAtMs) return;
  let score = Number.isFinite(recordMs) ? recordMs : 0;
  try {
    const stat = fs.statSync(file);
    if (!Number.isFinite(score)) score = stat.mtimeMs;
    score = Math.max(score, stat.mtimeMs || 0);
  } catch {}
  if (!best || score > best.score) best = { id: record.id, score };
}
function walk(dir) {
  let entries;
  try {
    entries = fs.readdirSync(dir, { withFileTypes: true });
  } catch {
    return;
  }
  for (const entry of entries) {
    const full = path.join(dir, entry.name);
    if (entry.isDirectory()) walk(full);
    else if (entry.isFile() && entry.name.endsWith('.jsonl')) consider(full);
  }
}
for (const root of roots) walk(root);
if (best?.id) process.stdout.write(best.id);
NODE
}

wait_for_gjc_session_id() {
  local roots="$1" target="$2"
  local discovered_session_id=''
  for _ in $(seq 1 40); do
    discovered_session_id="$(discover_gjc_session_id "$roots")"
    if [[ -n "$discovered_session_id" ]]; then
      tmux set-option -t "$target" -q '@gjc-session-id' "$discovered_session_id"
      printf '%s' "$discovered_session_id"
      return 0
    fi
    sleep 0.25
  done
  return 1
}

conflicting_gjc_session_target() {
  local session_id="$1" current_session="$2"
  local tmux_session tagged_session_id
  while IFS=$'\t' read -r tmux_session tagged_session_id; do
    [[ -n "$tmux_session" ]] || continue
    if [[ "$tagged_session_id" == "$session_id" && "$tmux_session" != "$current_session" ]]; then
      printf '%s' "$tmux_session"
      return 0
    fi
  done < <(tmux list-sessions -F '#{session_name}\t#{@gjc-session-id}' 2>/dev/null || true)
  return 1
}

apply_gjc_tags() {
  local target="$1" branch="$2" branch_slug="$3" project="$4" owner_key="$5" started_at="$6"
  tmux set-option -t "$target" -q '@gjc-profile' '1'
  tmux set-option -t "$target" -q '@gjc-branch' "$branch"
  tmux set-option -t "$target" -q '@gjc-branch-slug' "$branch_slug"
  tmux set-option -t "$target" -q '@gjc-project' "$project"
  tmux set-option -t "$target" -q '@gjc-owner-key' "$owner_key"
  tmux set-option -t "$target" -q '@gjc-started-at' "$started_at"
}

verify_gjc_tags() {
  local target="$1" branch="$2" branch_slug="$3" project="$4" owner_key="$5" started_at="$6"
  local actual_profile actual_branch actual_branch_slug actual_project actual_owner_key actual_started_at actual_session_id
  actual_profile="$(session_option_value "$target" '@gjc-profile')"
  actual_branch="$(session_option_value "$target" '@gjc-branch')"
  actual_branch_slug="$(session_option_value "$target" '@gjc-branch-slug')"
  actual_project="$(session_option_value "$target" '@gjc-project')"
  actual_owner_key="$(session_option_value "$target" '@gjc-owner-key')"
  actual_started_at="$(session_option_value "$target" '@gjc-started-at')"
  actual_session_id="$(session_option_value "$target" '@gjc-session-id')"
  [[ "$actual_profile" == '1' ]] || return 1
  [[ "$actual_branch" == "$branch" ]] || return 1
  [[ "$actual_branch_slug" == "$branch_slug" ]] || return 1
  [[ "$actual_project" == "$project" ]] || return 1
  [[ "$actual_owner_key" == "$owner_key" ]] || return 1
  [[ "$actual_started_at" == "$started_at" ]] || return 1
  [[ -n "$actual_session_id" ]] || return 1
}

cleanup_session() {
  if [[ "$created_session" -ne 1 ]]; then
    return 0
  fi
  cleanup_attempted=1
  if tmux has-session -t "$session_name" 2>/dev/null; then
    if tmux kill-session -t "$session_name" >/dev/null 2>&1; then
      cleanup_succeeded=1
      return 0
    fi
    cleanup_succeeded=0
    return 1
  fi
  cleanup_succeeded=1
}

fail_unmanaged_session() {
  local message="$1" branch="$2" branch_slug="$3" project="$4" command_text="$5"
  cleanup_session || true
  if [[ "$print_json" -eq 1 ]]; then
    emit_result_json false false "$message" "$command_text" "$branch" "$branch_slug" "$project" "${legacy_runs_dir:+unsupported}"
  else
    log "canonical helper: $canonical_name"
    log "$message"
    if [[ "$cleanup_attempted" -eq 1 && "$cleanup_succeeded" -ne 1 ]]; then
      log "cleanup required: unmanaged tmux session may still exist: $session_name"
    fi
  fi
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    --name|-n) [[ $# -ge 2 ]] || die "missing session name after --name"; session_name="$2"; shift 2 ;;
    --attach|-a) attach=1; shift ;;
    --direct|-d) direct_mode=1; shift ;;
    --json) print_json=1; shift ;;
    --runs|--runs-dir) [[ $# -ge 2 ]] || die "missing path after $1"; legacy_runs_dir="$2"; runs_dir_option=1; shift 2 ;;
    --no-check|--no-bridge-check) bridge_check=0; shift ;;
    --) shift; extra_args=("$@"); break ;;
    -*) die "unknown option: $1" ;;
    *) project_dir="$1"; shift ;;
  esac
done

project_dir="$(cd "$project_dir" && pwd)"
[[ "$runs_dir_option" -eq 0 ]] || die "--runs/--runs-dir is not supported on the branch-fixed gjc backend"
require_cmd gjc

if [[ "$direct_mode" -eq 1 ]]; then
  [[ "$attach" -eq 0 ]] || die "--direct/-d cannot be combined with --attach/-a"
  [[ "$print_json" -eq 0 ]] || die "--direct/-d does not create a managed tmux session, so --json is not available"
  [[ -z "$session_name" ]] || die "--direct/-d cannot be combined with --name"
  cmd=(gjc)
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    cmd+=("${extra_args[@]}")
  fi
  cd "$project_dir"
  exec "${cmd[@]}"
fi

require_cmd tmux

session_name="${session_name:-$(auto_name)}"
[[ "$session_name" =~ ^[[:alnum:]_.-]+$ ]] || die "invalid tmux session name: $session_name"

if tmux has-session -t "$session_name" 2>/dev/null; then
  die "tmux session already exists: $session_name"
fi

gjc_branch="${GJC_TMUX_BRANCH:-gjc}"
gjc_branch_slug="${GJC_TMUX_BRANCH_SLUG:-$(slugify "$gjc_branch")}"
gjc_project="${GJC_TMUX_PROJECT:-$(slugify "$(basename "$project_dir")")}"
gjc_started_at="$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)"
gjc_owner_key="${GJC_TMUX_OWNER_KEY:-${session_name}:${gjc_started_at}}"
gjc_session_roots_value="$(gjc_session_roots)"
gjc_session_id=''
cmd=(gjc)
if [[ ${#extra_args[@]} -gt 0 ]]; then
  cmd+=("${extra_args[@]}")
fi
cmd_text="exec $(quote_cmd "${cmd[@]}")"

tmux new-session -d -s "$session_name" -c "$project_dir" "$cmd_text"
created_session=1
apply_gjc_tags "$session_name" "$gjc_branch" "$gjc_branch_slug" "$gjc_project" "$gjc_owner_key" "$gjc_started_at" || fail_unmanaged_session "failed to apply required GJC tmux ownership tags" "$gjc_branch" "$gjc_branch_slug" "$gjc_project" "${cmd[*]}"
gjc_session_id="$(wait_for_gjc_session_id "$gjc_session_roots_value" "$session_name")" || fail_unmanaged_session "failed to discover and stamp the GJC session id for the managed tmux session" "$gjc_branch" "$gjc_branch_slug" "$gjc_project" "${cmd[*]}"
conflicting_session="$(conflicting_gjc_session_target "$gjc_session_id" "$session_name")"
[[ -z "$conflicting_session" ]] || fail_unmanaged_session "discovered GJC session id is already tagged on another managed tmux session: $conflicting_session" "$gjc_branch" "$gjc_branch_slug" "$gjc_project" "${cmd[*]}"
verify_gjc_tags "$session_name" "$gjc_branch" "$gjc_branch_slug" "$gjc_project" "$gjc_owner_key" "$gjc_started_at" || fail_unmanaged_session "tmux session failed GJC ownership verification; refusing to report it as managed" "$gjc_branch" "$gjc_branch_slug" "$gjc_project" "${cmd[*]}"

sleep 1
pane_id="$(tmux list-panes -t "$session_name" -F '#{pane_id}' | head -n 1)"

if [[ "$bridge_check" -eq 1 ]]; then
  bridge_url="${OMX_BRIDGE_URL:-http://127.0.0.1:3037}"
  if command -v curl >/dev/null 2>&1; then
    curl -fsS --max-time 2 "$bridge_url/health" >/dev/null 2>&1 || true
  fi
fi

if [[ "$print_json" -eq 1 ]]; then
  emit_result_json true true "managed GJC tmux session created" "${cmd[*]}" "$gjc_branch" "$gjc_branch_slug" "$gjc_project" ""
else
  log "managed GJC tmux session created: $session_name ($pane_id)"
  log "canonical helper: $canonical_name"
  log "project: $project_dir"
  log "command: ${cmd[*]}"
  log "bridge endpoint: ${OMX_BRIDGE_URL:-http://127.0.0.1:3037}/sessions"
fi

if [[ "$attach" -eq 1 ]]; then
  if [[ -n "${TMUX:-}" ]]; then
    exec tmux switch-client -t "$session_name"
  else
    exec tmux attach-session -t "$session_name"
  fi
fi
