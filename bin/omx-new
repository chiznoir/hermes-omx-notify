#!/usr/bin/env bash
set -euo pipefail

script_name="$(basename "$0")"
project_dir="$PWD"
session_name=""
attach=0
direct_mode=0
print_json=0
bridge_check=1
omx_runs_dir="${OMX_RUNS_DIR:-}"
runs_dir_option=0
extra_args=()

usage() {
  cat <<'USAGE'
사용법:
  omx-new [PROJECT_DIR] [--name SESSION] [--attach] [--direct] [--json] [--runs PATH] [--no-check] [-- OMX_ARGS...]

설명:
  기본적으로 새 OMX/Codex TUI 세션을 native tmux로 시작하고 `omx --madmax --high`를 실행합니다.
  `--direct`/`-d` 지정 시 tmux 세션을 만들지 않고 현재 터미널에서 `omx --direct --yolo`를 실행합니다.
  tmux 모드에서도 내부 명령에 `--tmux`를 넣지 않습니다.
  --runs PATH를 지정하면 해당 경로를 omx 실행 로그 디렉터리로 전달합니다.
  `--direct`와 `--disable codex_hooks`는 기본값으로 사용하지 않습니다.
  `--direct`/`-d`는 `--attach`/`-a`, `--name`, `--json`과 함께 사용할 수 없습니다.

예시:
  omx-new ~/work/omx-bridge
  omx-new . --name omx-bridge-main --attach
  omx-new ~/work/app -d
  omx-new ~/work/app -- --model gpt-5.5
USAGE
}

section() { printf '\n🔧 %s\n' "$*" >&2; }
log() { printf '  • %s\n' "$*" >&2; }
ok() { printf '✅ %s\n' "$*" >&2; }
die() { printf '❌ %s\n' "$*" >&2; exit 1; }
trap 'rc=$?; printf "❌ 실패: line=%s exit=%s\n" "$LINENO" "$rc" >&2; exit "$rc"' ERR
require_cmd() { command -v "$1" >/dev/null 2>&1 || die "필요한 명령어를 찾을 수 없습니다: $1"; }

slugify() {
  local raw="$1" slug
  slug="$(printf '%s' "$raw" | tr -cs '[:alnum:]_.-' '-' | sed 's/^-*//; s/-*$//')"
  printf '%s' "${slug:-project}"
}

auto_name() {
  printf 'omx-%s-%s' "$(slugify "$(basename "$project_dir")")" "$(date +%H%M%S)"
}

quote_cmd() {
  local out=() arg
  for arg in "$@"; do
    out+=("$(printf '%q' "$arg")")
  done
  printf '%s ' "${out[@]}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    --name|-n) [[ $# -ge 2 ]] || die "--name 뒤에 세션명이 필요합니다"; session_name="$2"; shift 2 ;;
    --attach|-a) attach=1; shift ;;
    --direct|-d) direct_mode=1; shift ;;
    --json) print_json=1; shift ;;
    --runs|--runs-dir) [[ $# -ge 2 ]] || die "$1 뒤에 경로가 필요합니다"; omx_runs_dir="$2"; runs_dir_option=1; shift 2 ;;
    --no-check|--no-bridge-check) bridge_check=0; shift ;;
    --) shift; extra_args=("$@"); break ;;
    -*) die "알 수 없는 옵션: $1" ;;
    *) project_dir="$1"; shift ;;
  esac
done

require_cmd omx

project_dir="$(cd "$project_dir" && pwd)"
if [[ "$runs_dir_option" -eq 1 ]]; then
  mkdir -p "$omx_runs_dir"
  omx_runs_dir="$(cd "$omx_runs_dir" && pwd)"
fi

if [[ "$direct_mode" -eq 1 ]]; then
  [[ "$attach" -eq 0 ]] || die "--direct/-d는 tmux 세션을 만들지 않으므로 --attach/-a와 함께 사용할 수 없습니다"
  [[ "$print_json" -eq 0 ]] || die "--direct/-d는 tmux 세션 정보를 만들지 않으므로 --json과 함께 사용할 수 없습니다"
  [[ -z "$session_name" ]] || die "--direct/-d는 tmux 세션을 만들지 않으므로 --name과 함께 사용할 수 없습니다"
  cmd=(omx --direct --yolo)
  if [[ -n "$omx_runs_dir" ]]; then
    cmd=(env "OMX_RUNS_DIR=$omx_runs_dir" "${cmd[@]}")
  fi
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    cmd+=("${extra_args[@]}")
  fi
  cd "$project_dir"
  exec "${cmd[@]}"
fi

require_cmd tmux

session_name="${session_name:-$(auto_name)}"
[[ "$session_name" =~ ^[[:alnum:]_.-]+$ ]] || die "유효하지 않은 tmux session 이름: $session_name"

if tmux has-session -t "$session_name" 2>/dev/null; then
  die "이미 존재하는 tmux session입니다: $session_name"
fi

cmd=(omx --madmax --high)
if [[ -n "$omx_runs_dir" ]]; then
  cmd=(env "OMX_RUNS_DIR=$omx_runs_dir" "${cmd[@]}")
fi
if [[ ${#extra_args[@]} -gt 0 ]]; then
  cmd+=("${extra_args[@]}")
fi

# Do not use `omx --tmux` here. We create the tmux session explicitly for Hermes/headless launch.
# Inside tmux, OMX resolves to inside-tmux mode and may create only its HUD pane, not another session.
cmd_text="exec $(quote_cmd "${cmd[@]}")"
tmux new-session -d -s "$session_name" -c "$project_dir" "$cmd_text"

sleep 1
pane_id="$(tmux list-panes -t "$session_name" -F '#{pane_id}' | head -n 1)"

if [[ "$bridge_check" -eq 1 ]]; then
  bridge_url="${OMX_BRIDGE_URL:-http://127.0.0.1:3037}"
  if command -v curl >/dev/null 2>&1; then
    curl -fsS --max-time 2 "$bridge_url/health" >/dev/null 2>&1 || true
  fi
fi

if [[ "$print_json" -eq 1 ]]; then
  if command -v jq >/dev/null 2>&1; then
    jq -n --arg session "$session_name" --arg pane "$pane_id" --arg dir "$project_dir" --arg runsDir "$omx_runs_dir" --arg command "${cmd[*]}" \
      '{ok:true, tmuxId:$session, tmuxPaneId:$pane, projectDir:$dir, command:$command} + (if $runsDir == "" then {} else {omxRunsDir:$runsDir} end)'
  else
    if [[ -n "$omx_runs_dir" ]]; then
      printf '{"ok":true,"tmuxId":"%s","tmuxPaneId":"%s","projectDir":"%s","omxRunsDir":"%s"}\n' "$session_name" "$pane_id" "$project_dir" "$omx_runs_dir"
    else
      printf '{"ok":true,"tmuxId":"%s","tmuxPaneId":"%s","projectDir":"%s"}\n' "$session_name" "$pane_id" "$project_dir"
    fi
  fi
else
  ok "시작 완료: $session_name ($pane_id)"
  log "프로젝트: $project_dir"
  if [[ -n "$omx_runs_dir" ]]; then
    log "omx 실행 로그: $omx_runs_dir"
  fi
  log "실행 명령: ${cmd[*]}"
  log "bridge endpoint: ${OMX_BRIDGE_URL:-http://127.0.0.1:3037}/sessions"
fi

if [[ "$attach" -eq 1 ]]; then
  if [[ -n "${TMUX:-}" ]]; then
    exec tmux switch-client -t "$session_name"
  else
    exec tmux attach-session -t "$session_name"
  fi
fi
