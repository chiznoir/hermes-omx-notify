#!/usr/bin/env bash
set -euo pipefail

script_name="$(basename "$0")"
canonical_name="tm-kill"
bridge_url="${OMX_BRIDGE_URL:-http://127.0.0.1:3037}"
token="${OMX_BRIDGE_TOKEN:-}"
session_id=""
project=""
tmux_id=""
force=0
dry_run=0
managed_session_name=""
managed_pane_id=""
managed_project=""

usage() {
  cat <<'USAGE'
Usage:
  tm-kill --session SESSION_ID [--force]
  tm-kill --project PROJECT [--force]
  tm-kill --tmux TMUX_TARGET [--force]

Description:
  Canonical helper on gajae-version is tm-kill.
  The final action is local tmux kill-session, but only for managed GJC sessions.
  Direct --tmux targets must already carry verified GJC ownership tags:
    @gjc-profile=1, @gjc-branch=gjc, @gjc-branch-slug, @gjc-project
USAGE
}

log() { printf '%s\n' "$*" >&2; }
die() { printf 'error: %s\n' "$*" >&2; exit 1; }
require_cmd() { command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"; }

slugify() {
  local raw="$1" slug
  slug="$(printf '%s' "$raw" | tr -cs '[:alnum:]_.-' '-' | sed 's/^-*//; s/-*$//')"
  printf '%s' "${slug:-project}"
}

load_managed_tmux_target() {
  local target="$1" raw expected_slug
  managed_error="tmux target not found or not addressable: $target"
  raw="$(tmux display-message -p -t "$target" '#{session_name}	#{pane_id}	#{@gjc-profile}	#{@gjc-branch}	#{@gjc-branch-slug}	#{@gjc-project}	#{@gjc-owner-key}	#{@gjc-started-at}	#{@gjc-session-id}' 2>/dev/null)" || return 1
  IFS=$'\t' read -r managed_session_name managed_pane_id managed_gjc_profile managed_gjc_branch managed_gjc_branch_slug managed_project managed_gjc_owner_key managed_gjc_started_at managed_gjc_session_id <<<"$raw"
  [[ "$managed_gjc_profile" == '1' ]] || { managed_error="unmanaged tmux target: missing @gjc-profile=1"; return 1; }
  [[ "$managed_gjc_branch" == 'gjc' ]] || { managed_error="unmanaged tmux target: expected @gjc-branch=gjc, got ${managed_gjc_branch:-<empty>}"; return 1; }
  expected_slug="$(slugify "$managed_gjc_branch")"
  [[ "$managed_gjc_branch_slug" == "$expected_slug" ]] || { managed_error="unmanaged tmux target: expected @gjc-branch-slug=$expected_slug, got ${managed_gjc_branch_slug:-<empty>}"; return 1; }
  [[ -n "$managed_project" ]] || { managed_error='unmanaged tmux target: missing @gjc-project'; return 1; }
  [[ -n "$managed_gjc_owner_key" ]] || { managed_error='unmanaged tmux target: missing @gjc-owner-key'; return 1; }
  [[ -n "$managed_gjc_started_at" ]] || { managed_error='unmanaged tmux target: missing @gjc-started-at'; return 1; }
  [[ -n "$managed_gjc_session_id" ]] || { managed_error='unmanaged tmux target: missing @gjc-session-id'; return 1; }
}

auth_args=()
if [[ -n "$token" ]]; then auth_args=(-H "Authorization: Bearer $token"); fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    --url|--bridge-url) [[ $# -ge 2 ]] || die "missing URL after $1"; bridge_url="$2"; shift 2 ;;
    --token) [[ $# -ge 2 ]] || die 'missing token after --token'; token="$2"; auth_args=(-H "Authorization: Bearer $token"); shift 2 ;;
    --session|-s) [[ $# -ge 2 ]] || die 'missing id after --session'; session_id="$2"; shift 2 ;;
    --project|-p) [[ $# -ge 2 ]] || die 'missing project after --project'; project="$2"; shift 2 ;;
    --tmux|--tmux-id) [[ $# -ge 2 ]] || die "missing tmux target after $1"; tmux_id="$2"; shift 2 ;;
    --force|-f) force=1; shift ;;
    --dry|--dry-run) dry_run=1; shift ;;
    -*) die "unknown option: $1" ;;
    *) die "unknown argument: $1" ;;
  esac
done

require_cmd tmux
if [[ -z "$tmux_id" ]]; then
  require_cmd curl
  require_cmd jq
  sessions_json="$(curl -fsS "${auth_args[@]}" "$bridge_url/sessions")"
  if [[ -n "$session_id" ]]; then
    tmux_id="$(jq -r --arg id "$session_id" '.sessions[] | select(.bridgeSessionId==$id or .codexSessionId==$id or .omxSessionId==$id or .tmuxId==$id or .tmuxPaneId==$id) | .tmuxId // empty' <<<"$sessions_json" | head -n 1)"
  elif [[ -n "$project" ]]; then
    tmux_id="$(jq -r --arg project "$project" '[.sessions[] | select(.project==$project and .status!="ended" and (.tmuxId != null))] | sort_by(.lastEventAt // .startedAt // "") | reverse | .[0].tmuxId // empty' <<<"$sessions_json")"
  else
    die '--session, --project, or --tmux is required'
  fi
fi

[[ -n "$tmux_id" ]] || die 'failed to resolve tmux session to kill'
if ! tmux has-session -t "$tmux_id" 2>/dev/null; then
  die "tmux session does not exist: $tmux_id"
fi
load_managed_tmux_target "$tmux_id" || die "$managed_error"

if [[ "$dry_run" -eq 1 ]]; then
  log "managed tmux kill preview: tmux kill-session -t $managed_session_name"
  exit 0
fi

if [[ "$force" -ne 1 ]]; then
  if [[ ! -t 0 || ! -t 1 ]]; then
    die "non-interactive use requires --force for managed tmux session: $managed_session_name"
  fi
  printf 'kill managed tmux session %s (project=%s)? [y/N]: ' "$managed_session_name" "$managed_project" >&2
  read -r answer
  case "$answer" in y|Y|yes|YES) ;; *) log 'cancelled'; exit 0 ;; esac
fi

tmux kill-session -t "$managed_session_name"
log "managed tmux session killed: $managed_session_name"
if [[ "$script_name" != "$canonical_name" ]]; then
  log "legacy shim in use: $script_name is non-canonical on gajae-version"
fi
